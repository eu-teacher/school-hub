# Copy this file to .env and fill in your values
# Never commit .env to git!

# Secret key for JWT tokens — change this to something random and long
JWT_SECRET=troque_isso_por_uma_frase_secreta_longa_aqui

# Port (Railway sets this automatically, leave as is)
PORT=3000

# Supabase — encontrado em Project Settings > API no painel do Supabase
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_KEY=sua_service_role_key_aqui

# Hash da senha de login — gere com: node setup-password.js
ADMIN_PASSWORD_HASH=
